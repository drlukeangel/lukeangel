---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '@jdevalk/astro-seo-graph/Seo.astro';
import { getImage } from 'astro:assets';
import defaultOgImage from '../assets/pages/luke-angel-profile.jpg';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  current?: string;
  image?: string;
  ogType?: 'website' | 'article';
}

const defaultOg = await getImage({ src: defaultOgImage, format: 'webp', width: 1200, height: 630 });

const {
  title,
  description = 'Luke Angel — product, programs, AI, and a daily ledger of small thank-yous.',
  current,
  image = defaultOg.src,
  ogType = 'website',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#2a52be" />

  <!-- Favicon — the cropped-wing mark from lukeangel.co -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />
  <link rel="mask-icon" href="/favicon.png" color="#2a52be" />

  <Seo
    title={title}
    description={description}
    ogType={ogType}
    ogImage={new URL(image, Astro.site).toString()}
    ogImageAlt={title}
    siteName="Luke Angel"
    twitter={{ card: 'summary_large_image' }}
    extraLinks={[
      { rel: 'alternate', type: 'application/rss+xml', title: 'Luke Angel — The Journal', href: '/rss.xml' },
      { rel: 'sitemap', href: '/sitemap-index.xml' },
    ]}
  />

  <!-- Fonts — preconnect, then load non-blocking via media-swap trick -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;700&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;700&display=swap" />
  </noscript>

  <!-- Pagefind UI for /search page -->
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

  <!-- Google Analytics (GA4) — deferred, fires after page is interactive -->
  <script defer src="https://www.googletagmanager.com/gtag/js?id=G-QEMMZ9SQJ4"></script>
  <script is:inline defer>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-QEMMZ9SQJ4');
  </script>
</head>
<body>
  <Header current={current} />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
