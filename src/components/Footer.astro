---
// Footer with theme toggle (light/dark) — moon glyph
---
<footer class="site">
  <div class="inner">
    <div style="font-weight: 600; font-size: 22px;">Luke Angel</div>
    <div class="nav">
      <a href="/">home</a>
      <a href="/about/">about</a>
      <a href="/courses/">courses</a>
      <a href="/blog/">blog</a>
      <a href="/projects/">projects</a>
      <a href="/contact/">contact</a>
      <button class="mode-toggle" id="mode-toggle" aria-label="Toggle dark mode">
        <svg id="moon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg id="sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
      </button>
    </div>
  </div>
  <div class="inner" style="margin-top: 18px;">
    <div class="mono">BUILT WITH AN ATTITUDE OF GRATITUDE · © 2026 L. ANGEL</div>
  </div>
</footer>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const saved = localStorage.getItem('theme');
    if (saved === 'dark') root.setAttribute('data-theme', 'dark');

    const btn = document.getElementById('mode-toggle');
    const moon = document.getElementById('moon');
    const sun  = document.getElementById('sun');
    const sync = () => {
      const dark = root.getAttribute('data-theme') === 'dark';
      moon.style.display = dark ? 'none' : '';
      sun.style.display  = dark ? '' : 'none';
    };
    sync();
    btn?.addEventListener('click', () => {
      const dark = root.getAttribute('data-theme') === 'dark';
      if (dark) { root.removeAttribute('data-theme'); localStorage.setItem('theme', 'light'); }
      else      { root.setAttribute('data-theme', 'dark'); localStorage.setItem('theme', 'dark'); }
      sync();
    });
  })();
</script>
