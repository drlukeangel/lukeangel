---
// Reusable subscribe block. Drop into any page.
// Usage: <SubscribeBlock /> or <SubscribeBlock variant="dark" />
const { variant = 'light', heading = 'Get the journal by email.', sub = 'Twice a month-ish. Unsubscribe with gratitude.' } = Astro.props;
const isDark = variant === 'dark';
---
<div class="card" style={`padding: 28px; ${isDark ? 'background: var(--ink); color: var(--paper);' : ''}`}>
  <div class="mono" style={`color: ${isDark ? 'var(--accent)' : 'var(--accent)'};`}>Subscribe</div>
  <h3 style={`font-size: 24px; margin-top: 8px; line-height: 1.2; ${isDark ? 'color: var(--paper);' : ''}`}>{heading}</h3>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/drlukeangel"
    method="post"
    target="popupwindow"
    onsubmit="window.open('https://buttondown.com/drlukeangel', 'popupwindow')"
    style="display: flex; gap: 10px; margin-top: 14px;"
  >
    <input
      type="email" name="email" required placeholder="you@inbox.com"
      style={`flex: 1; padding: 12px 14px; border: 1px solid ${isDark ? 'rgba(255,255,255,0.2)' : 'var(--rule)'}; background: ${isDark ? 'transparent' : 'var(--paper)'}; color: ${isDark ? 'var(--paper)' : 'var(--ink)'}; font-family: 'Newsreader', serif; font-size: 16px; border-radius: 4px;`}
    />
    <button
      type="submit"
      style={`padding: 12px 22px; background: ${isDark ? 'var(--accent)' : 'var(--ink)'}; color: ${isDark ? 'var(--paper)' : 'var(--paper)'}; border: none; font-family: 'Newsreader', serif; font-size: 16px; cursor: pointer; border-radius: 999px;`}
    >Subscribe</button>
  </form>
  <div style={`font-style: italic; font-size: 13px; margin-top: 12px; color: ${isDark ? 'rgba(244,241,232,0.6)' : 'var(--muted)'};`}>{sub}</div>
</div>
