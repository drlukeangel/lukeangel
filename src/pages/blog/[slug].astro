---
import Base from '../../layouts/Base.astro';
import EditInKeystatic from '../../components/EditInKeystatic.astro';
import JsonLd from '../../components/JsonLd.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { isLive } from '../../lib/posts';
import { Image, getImage } from 'astro:assets';
import fallbackOg from '../../assets/pages/luke-angel-profile.jpg';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => isLive(data));
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// If this post belongs to a series, fetch the series + sibling posts
let seriesEntry: any = null;
let seriesSiblings: any[] = [];
let seriesIndex = -1;
if (post.data.notebook) {
  const allSeries = await getCollection('notebooks');
  seriesEntry = allSeries.find((s) => s.slug === post.data.notebook) ?? null;
  if (seriesEntry) {
    const allInSeries = await getCollection('blog', ({ data }) => isLive(data));
    seriesSiblings = allInSeries
      .filter((p) => p.data.notebook === post.data.notebook)
      .sort((a, b) => {
        const ao = a.data.notebookOrder ?? 999;
        const bo = b.data.notebookOrder ?? 999;
        if (ao !== bo) return ao - bo;
        return a.data.date.getTime() - b.data.date.getTime();
      });
    seriesIndex = seriesSiblings.findIndex((p) => p.slug === post.slug);
  }
}

const canonical = new URL(`/blog/${post.slug}/`, Astro.site).toString();
const ogImageMeta = post.data.cover
  ? await getImage({ src: post.data.cover, format: 'webp', width: 1200, height: 630 })
  : await getImage({ src: fallbackOg, format: 'webp', width: 1200, height: 630 });
const ogImage = new URL(ogImageMeta.src, Astro.site).toString();

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  image: ogImage,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Luke Angel',
    url: new URL('/about/', Astro.site).toString(),
  },
  publisher: {
    '@type': 'Person',
    name: 'Luke Angel',
    url: Astro.site?.toString(),
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
  keywords: post.data.tags?.join(', '),
  articleSection: post.data.category,
};

const faqSchema = post.data.faq && post.data.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.data.faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    }
  : null;

// Auto-related posts: tag overlap + category match, scored
const all = await getCollection('blog', ({ data }) => isLive(data));
const related = all
  .filter((p) => p.slug !== post.slug)
  .map((p) => ({
    p,
    overlap:
      p.data.tags.filter((t) => post.data.tags.includes(t)).length +
      (p.data.category === post.data.category ? 1 : 0),
  }))
  .filter((x) => x.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap)
  .slice(0, 3)
  .map((x) => x.p);
---
<Base title={post.data.title} current="blog" description={post.data.excerpt} image={ogImage} ogType="article">
  <JsonLd data={blogPostingSchema} />
  {faqSchema && <JsonLd data={faqSchema} />}
  <article class="post wrap" style="padding: 40px 32px;" data-pagefind-body>
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'The Journal', href: '/blog/' },
      { label: post.data.title },
    ]} />

    <!-- Cover band: real image when set, fallback panel otherwise -->
    {post.data.cover ? (
      <Image
        src={post.data.cover}
        alt={post.data.coverAlt || post.data.title}
        widths={[480, 960, 1440, 1920]}
        sizes="(max-width: 720px) 100vw, 1440px"
        loading="eager"
        style="display:block; width:100%; height:320px; object-fit:cover; margin-top:24px; border:1px solid var(--rule);"
      />
    ) : (
      <div style="margin-top: 24px; height: 220px; background: var(--paper); border: 1px solid var(--rule); position: relative;">
        <a href={`/category/${post.data.category}/`} style="position: absolute; top: 16px; left: 20px; background: var(--ink); color: var(--paper); padding: 6px 12px;" class="mono">{post.data.category}</a>
        <div style="position: absolute; bottom: 16px; right: 20px;" class="mono">{post.data.date.toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' })}</div>
      </div>
    )}

    <!-- Title block -->
    <div style="max-width: 1100px; margin: 32px auto 0; text-align: center;">
      <div class="mono" style="color: var(--accent);"><a href={`/category/${post.data.category}/`} style="color: var(--accent);">{post.data.category}</a></div>
      <h1 style="font-size: clamp(48px, 6vw, 84px); margin-top: 14px; max-width: 940px; margin-left: auto; margin-right: auto;">{post.data.title}</h1>
      <div style="font-style: italic; color: var(--muted); margin-top: 14px;">by <a href="/about/" style="color: inherit; text-decoration: underline; text-decoration-color: var(--accent);" rel="author">Luke Angel</a></div>
      <div style="display: flex; justify-content: center; gap: 8px; margin-top: 20px; flex-wrap: wrap;">
        {post.data.tags.map((t) => (
          <a href={`/tag/${t}/`} class="chip">#{t}</a>
        ))}
      </div>
    </div>

    <!-- Body -->
    <div style="max-width: 960px; margin: 56px auto 0; font-size: 19px; line-height: 1.75;">
      {seriesEntry && (
        <aside style={`background: var(--paper); border-left: 6px solid ${seriesEntry.data.accent ?? 'var(--accent)'}; padding: 20px 24px; margin-bottom: 40px;`}>
          <div class="mono" style={`color: ${seriesEntry.data.accent ?? 'var(--accent)'};`}>
            Part {seriesIndex >= 0 ? seriesIndex + 1 : '?'} of {seriesSiblings.length} · Notebook
          </div>
          <a href={`/notebooks/${seriesEntry.slug}/`} style="font-size: 24px; display: block; margin-top: 8px; color: var(--ink); text-decoration: underline; text-underline-offset: 4px;">{seriesEntry.data.title}</a>
          <ol style="list-style: none; padding: 0; margin: 14px 0 0;">
            {seriesSiblings.map((p, i) => {
              const isMe = p.slug === post.slug;
              return (
                <li style="display: flex; gap: 10px; padding: 4px 0; align-items: baseline;">
                  <span class="mono" style={`color: ${isMe ? 'var(--ink)' : 'var(--muted)'};`}>{String(i + 1).padStart(2, '0')}</span>
                  {isMe ? (
                    <span style="font-style: italic; color: var(--ink); font-weight: 600;">
                      {p.data.title} <span class="mono" style="color: var(--accent); margin-left: 4px;">· you are here</span>
                    </span>
                  ) : (
                    <a href={`/blog/${p.slug}/`} style="color: var(--ink); text-decoration: none;">{p.data.title}</a>
                  )}
                </li>
              );
            })}
          </ol>
        </aside>
      )}
      <Content />
      {seriesEntry && seriesSiblings.length > 1 && (
        <nav style="margin-top: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 18px; border-top: 1px solid var(--rule); padding-top: 24px;">
          {seriesIndex > 0 ? (
            <a href={`/blog/${seriesSiblings[seriesIndex - 1].slug}/`} style="text-decoration: none; color: var(--ink);">
              <div class="mono" style="color: var(--accent);">← Previous in series</div>
              <div style="font-size: 18px; margin-top: 6px;">{seriesSiblings[seriesIndex - 1].data.title}</div>
            </a>
          ) : <span />}
          {seriesIndex >= 0 && seriesIndex < seriesSiblings.length - 1 ? (
            <a href={`/blog/${seriesSiblings[seriesIndex + 1].slug}/`} style="text-decoration: none; color: var(--ink); text-align: right;">
              <div class="mono" style="color: var(--accent);">Next in series →</div>
              <div style="font-size: 18px; margin-top: 6px;">{seriesSiblings[seriesIndex + 1].data.title}</div>
            </a>
          ) : <span />}
        </nav>
      )}
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <div style="max-width: 1100px; margin: 56px auto 0; padding-top: 28px; border-top: 2px solid var(--ink);">
        <div style="display: flex; justify-content: space-between; align-items: baseline;">
          <h3 style="font-size: 24px;">Keep reading</h3>
          <div class="mono">shares tags: {post.data.tags.slice(0, 2).map((t) => '#' + t).join(' · ')}</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 18px;">
          {related.map((r) => (
            <a href={`/blog/${r.slug}/`} class="card">
              <div class="mono" style="color: var(--accent);">{r.data.category}</div>
              <div style="font-size: 18px; margin-top: 10px;">{r.data.title}</div>
              <div class="mono" style="margin-top: 12px;">{r.data.date.toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}</div>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
  <EditInKeystatic collection="blog" slug={post.slug} />
</Base>
