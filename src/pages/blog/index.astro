---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { isLive } from '../../lib/posts';
import SubscribeBlock from '../../components/SubscribeBlock.astro';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog', ({ data }) => isLive(data)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// All categories that actually have at least one post, sorted in schema order.
const schemaOrder = ['method', 'teams', 'craft', 'tools', 'people', 'projects', 'programs', 'product', 'give'];
const used = new Set(posts.map((p) => p.data.category));
const categories = schemaOrder.filter((c) => used.has(c));
const counts = Object.fromEntries(categories.map((c) => [c, posts.filter((p) => p.data.category === c).length]));

// Tag tallies — top 12 by count for the chip row, the rest live on /tags/.
const tagTally: Record<string, number> = {};
for (const p of posts) for (const t of p.data.tags) tagTally[t] = (tagTally[t] || 0) + 1;
const topTags = Object.entries(tagTally)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 12);
const totalTagCount = Object.keys(tagTally).length;

const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = featured ? posts.filter((p) => p.slug !== featured.slug) : [];

// Group rest posts by year, preserving newest-first order within each group.
type YearGroup = { year: number; posts: typeof rest };
const restByYear: YearGroup[] = [];
for (const p of rest) {
  const y = p.data.date.getFullYear();
  const last = restByYear[restByYear.length - 1];
  if (last && last.year === y) last.posts.push(p);
  else restByYear.push({ year: y, posts: [p] });
}

// Notebooks — priority order = most recently updated notebook first
const seriesList = (await getCollection('notebooks', ({ data }) => !data.draft));
const notebookMeta = seriesList.map((s) => {
  const inSeries = posts.filter((p) => p.data.notebook === s.slug);
  const lastUpdated = inSeries.length
    ? Math.max(...inSeries.map((p) => p.data.date.getTime()))
    : 0;
  const years = inSeries.map((p) => p.data.date.getFullYear());
  return {
    s,
    count: inSeries.length,
    lastUpdated,
    minYear: years.length ? Math.min(...years) : '',
    maxYear: years.length ? Math.max(...years) : '',
  };
})
  .filter((m) => m.count > 0)
  .sort((a, b) => b.lastUpdated - a.lastUpdated);
const topNotebooks = notebookMeta.slice(0, 3);
---
<Base title="The Journal — Notes on product, programs, and AI" current="blog" description="Notes from the desk — roughly weekly, mostly on product, programs, and AI, occasionally on gratitude. Written by Luke Angel.">
  <section class="wrap" style="padding: 56px 32px;">
    <div style="display: flex; align-items: flex-end; justify-content: space-between; border-bottom: 2px solid var(--ink); padding-bottom: 18px;">
      <div>
        <div class="mono" style="color: var(--accent);">The Journal</div>
        <h1 style="font-size: clamp(56px, 7vw, 88px); margin-top: 8px;">Notes from the <em style="color: var(--accent);">desk</em>.</h1>
      </div>
      <div style="text-align: right;">
        <div style="font-style: italic; color: var(--muted);">Roughly weekly. Mostly on product &amp; AI. Occasionally on gratitude.</div>
        <div class="mono" style="margin-top: 6px;">{posts.length} entries · {categories.length} categories</div>
      </div>
    </div>

    <!-- Notebooks — surfaced at the top of the journal, recency-first -->
    {topNotebooks.length > 0 && (
      <div style="margin-top: 32px;">
        <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
          <div>
            <div class="mono" style="color: var(--accent);">From the Bookcase</div>
            <h2 style="font-size: clamp(28px, 3.4vw, 40px); margin-top: 6px;">The <em style="color: var(--accent);">Notebooks</em>.</h2>
          </div>
          <a href="/notebooks/" style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink); border-bottom: 1.5px solid var(--accent); padding-bottom: 2px; text-decoration: none;">see all notebooks →</a>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 20px;">
          {topNotebooks.map((m) => {
            const range = m.minYear === m.maxYear ? `${m.minYear}` : `${m.minYear}–${m.maxYear}`;
            return (
              <a href={`/notebooks/${m.s.slug}/`} class="card" style="display: block; padding: 0; position: relative;">
                {m.s.data.cover ? (
                  <Image
                    src={m.s.data.cover}
                    alt={m.s.data.coverAlt || m.s.data.title}
                    widths={[320, 640, 960]}
                    sizes="(max-width: 720px) 100vw, 400px"
                    loading="lazy"
                    style="display:block; width:100%; height:180px; object-fit:cover;"
                  />
                ) : (
                  <div style="height: 180px; background: var(--bg);"></div>
                )}
                <div style="padding: 16px 20px 20px;">
                  <div class="mono" style="color: var(--muted);">Notebook · {m.count} {m.count === 1 ? 'part' : 'parts'}</div>
                  <div style="font-size: 22px; margin-top: 8px; line-height: 1.2; letter-spacing: -0.3px;">{m.s.data.title}</div>
                  <div style="display: flex; justify-content: space-between; align-items: baseline; margin-top: 14px; padding-top: 10px; border-top: 1px dashed var(--rule);" class="mono">
                    <span>{range}</span>
                    <span style="color: var(--muted);">open →</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- Articles / Notebooks tab row -->
    <div style="margin-top: 40px; padding-top: 28px; border-top: 1px solid var(--rule); display: flex; gap: 12px;">
      <a href="/blog/" class="chip ink">Articles</a>
      <a href="/notebooks/" class="chip">Notebooks</a>
    </div>

    <!-- Toolbar: category chips + search link (search pinned right; categories wrap) -->
    <div style="margin-top: 16px; display: flex; gap: 12px; align-items: flex-start;">
      <div style="flex: 1; display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
        <span class="mono" style="min-width: 80px; color: var(--muted);">category —</span>
        <a href="/blog/" class="chip ink">all</a>
        {categories.map((c) => (
          <a href={`/category/${c}/`} class="chip">{c} <span style="color: var(--muted); margin-left: 6px;">{counts[c]}</span></a>
        ))}
      </div>
      <a href="/search/" class="chip" style="flex-shrink: 0;">⌕ search</a>
    </div>

    <!-- Toolbar: top tag chips (view-all pinned right; tags wrap) -->
    <div style="margin-top: 10px; display: flex; gap: 12px; align-items: flex-start;">
      <div style="flex: 1; display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
        <span class="mono" style="min-width: 80px; color: var(--muted);">tag —</span>
        {topTags.map(([t, n]) => (
          <a href={`/tag/${t}/`} class="chip">#{t} <span style="color: var(--muted); margin-left: 6px;">{n}</span></a>
        ))}
      </div>
      <a href="/tags/" class="chip" style="flex-shrink: 0; font-style: italic;">view all {totalTagCount} →</a>
    </div>

    <!-- Featured -->
    {featured ? (
      <a href={`/blog/${featured.slug}/`} class="card" style="display: grid; grid-template-columns: 1fr 1fr; gap: 36px; margin-top: 32px; padding: 0; align-items: stretch;">
        {featured.data.cover ? (
          <Image src={featured.data.cover} alt={featured.data.coverAlt || featured.data.title} widths={[480, 800, 1200]} sizes="(max-width: 720px) 100vw, 600px" loading="eager" style="display:block; width:100%; height:100%; min-height:320px; object-fit:cover;" />
        ) : (
          <div style="background: var(--bg); min-height: 320px; display: flex; align-items: center; justify-content: center;">
            <div class="mono" style="color: var(--accent);">Featured · {featured.data.category}</div>
          </div>
        )}
        <div style="padding: 36px;">
          <div class="mono" style="color: var(--accent);">{featured.data.category} · {featured.data.date.toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}</div>
          <h2 style="font-size: 44px; margin-top: 12px;">{featured.data.title}</h2>
          <p style="font-style: italic; color: var(--muted); margin-top: 14px;">“{featured.data.pullquote ?? featured.data.excerpt}”</p>
          <div style="margin-top: 24px; color: var(--accent); text-decoration: underline; text-underline-offset: 4px;">keep reading →</div>
        </div>
      </a>
    ) : (
      <div style="padding: 56px 0; text-align: center; color: var(--muted); font-style: italic;">
        No posts loaded — content collection returned empty. Try restarting the dev server.
      </div>
    )}

    <!-- Mosaic grid — grouped by year with separator rows -->
    {restByYear.map((group, gi) => (
      <Fragment>
        <div style={`display: grid; grid-template-columns: auto 1fr auto; gap: 24px; align-items: center; margin-top: ${gi === 0 ? 40 : 56}px;`}>
          <div style="font-family: 'Newsreader', serif; font-size: 52px; font-weight: 500; letter-spacing: -1.6px; line-height: 1;">{group.year}</div>
          <div style="height: 1px; background: var(--ink);"></div>
          <div class="mono">{group.posts.length} {group.posts.length === 1 ? 'entry' : 'entries'}</div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 24px;">
          {group.posts.map((p) => (
            <a href={`/blog/${p.slug}/`} class="card" style="display: block; padding: 0;">
              {p.data.cover && (
                <Image src={p.data.cover} alt={p.data.coverAlt || p.data.title} widths={[240, 480, 720]} sizes="(max-width: 720px) 100vw, 400px" loading="lazy" style="display:block; width:100%; height:180px; object-fit:cover;" />
              )}
              <div style="padding: 22px 24px 24px;">
                <div class="mono" style="color: var(--accent);">{p.data.category}</div>
                <div style="font-size: 22px; margin-top: 10px; line-height: 1.2;">{p.data.title}</div>
                <div style="font-style: italic; color: var(--muted); margin-top: 10px;">“{p.data.pullquote ?? p.data.excerpt}”</div>
                <div style="display: flex; justify-content: space-between; margin-top: 18px; padding-top: 12px; border-top: 1px dashed var(--rule);" class="mono">
                  <span>{p.data.date.toLocaleDateString('en-US', { month: 'short', day: '2-digit' })}</span>
                  <span style="color: var(--accent);">read →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </Fragment>
    ))}

    <!-- Subscribe -->
    <div style="margin-top: 56px;">
      <SubscribeBlock heading="Subscribe to the journal." sub="New posts in your inbox, twice a month-ish. Unsubscribe with gratitude." />
    </div>
  </section>
</Base>
