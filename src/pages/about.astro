---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import lukeAbout from '../assets/pages/luke-angel-profile-about.jpg';
---
<Base title="About Luke Angel — Engineer turned PM and PgM" current="about" description="Engineer turned program manager who never quit reading PRs. A short bio, the through-line, and what I'm working on right now.">
  <section class="wrap" style="padding: 56px 32px; max-width: 1400px;">
    <div class="mono" style="color: var(--accent);">About the author</div>
    <h1 style="font-size: clamp(56px, 7vw, 88px); margin-top: 14px;">Twelve years of <em style="color: var(--accent);">shipping</em>.</h1>
    <div style="display: grid; grid-template-columns: 320px minmax(0, 960px); gap: 56px; margin-top: 48px; align-items: start;">
      <div style="background: var(--paper); padding: 16px; border: 1px solid var(--rule); box-shadow: 0 12px 40px rgba(26,29,36,0.10);">
        <Image
          src={lukeAbout}
          alt="Portrait of Luke Angel — engineer, PM, PgM, and teacher"
          widths={[320, 640, 960]}
          sizes="(max-width: 720px) 90vw, 480px"
          loading="eager"
          style="display: block; width: 100%; height: auto; aspect-ratio: 4/5; object-fit: cover; background: var(--bg);"
        />
      </div>
      <div>
        <p style="font-size: 22px; line-height: 1.55;">I'm a technical product, program, and portfolio manager who never quit being an engineer. I write the roadmaps, build the plans, read the PRs, write the evals, and ship. Fortune 500s, startups, and everything between.</p>
        <p style="font-size: 19px; line-height: 1.6; margin-top: 22px; color: var(--muted);">My working philosophy is an <em>attitude of gratitude</em> — shipping is a team sport. Count the thank-yous, not the commits.</p>
        <div style="margin-top: 56px;">
          <div class="mono" style="color: var(--accent);">Chronology</div>
          <div style="margin-top: 20px; border-top: 1px solid var(--ink);">
            {[
              ['2019 — now', 'Visa', 'Sr. Director, Technical Program / Product Management — IaaS, Engineering & Architecture'],
              ['2017 — 19', 'Philips', 'Director, Technical Program Manager — Connected Applications & IoT Devices'],
              ['2016 — 17', 'NFL Media', 'Senior Technical Program Manager — Mobile & Connected Devices'],
              ['2014 — 16', 'DIRECTV', 'Senior Technical Cross-Platform Product Manager'],
              ['2012 — 14', 'Cornerstone OnDemand', 'Senior Technical Product Manager, Mobile'],
              ['2011 — 12', 'NBCUniversal', 'Senior Technical Product Manager'],
              ['2009 — 11', 'Mobile Messenger', 'Technical Product Manager'],
              ['1995 — 2009', 'Various companies', 'Architecture & Engineering'],
            ].map(([y, c, d]) => (
              <div style="display: grid; grid-template-columns: 140px 220px 1fr; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--rule); align-items: baseline;">
                <div class="mono">{y}</div>
                <div style="font-size: 17px; font-style: italic;">{c}</div>
                <div style="color: var(--muted); font-size: 15px;">{d}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
