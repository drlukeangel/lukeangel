---
import Base from '../layouts/Base.astro';
---
<Base title="Search" current="blog" description="Search the journal — by title, tag, or excerpt.">
  <section class="wrap" style="padding: 56px 32px;">
    <div class="mono" style="color: var(--accent);">Search</div>
    <h1 style="font-size: clamp(56px, 7vw, 88px); margin-top: 8px;">Find a <em style="color: var(--accent);">note</em>.</h1>
    <p style="font-style: italic; color: var(--muted); margin-top: 14px;">Indexed at build time by Pagefind. Searches titles, body text, tags, and excerpts.</p>

    <div id="search" style="margin-top: 32px;"></div>
  </section>

  <script type="module">
    import { PagefindUI } from '/pagefind/pagefind-ui.js';
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      resetStyles: false,
      translations: {
        placeholder: 'evals, prompting, gratitude…',
        clear_search: 'Clear',
        zero_results: 'Nothing matched "[SEARCH_TERM]". Try a tag, or browse all entries.',
      },
    });
  </script>
  <style is:global>
    .pagefind-ui__search-input {
      font-family: 'Newsreader', serif !important;
      font-size: 22px !important;
      padding: 16px 18px !important;
      border: 2px solid var(--ink) !important;
      background: var(--paper) !important;
      color: var(--ink) !important;
      border-radius: 0 !important;
    }
    .pagefind-ui__result {
      padding: 16px 0;
      border-bottom: 1px dashed var(--rule);
    }
    .pagefind-ui__result-title { font-family: 'Newsreader', serif; font-size: 22px; }
    .pagefind-ui__result-link { color: var(--ink) !important; text-decoration: none !important; }
    .pagefind-ui__result-link:hover { color: var(--accent) !important; }
  </style>
</Base>
