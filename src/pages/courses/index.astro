---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const courses = (await getCollection('courses', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---
<Base title="Courses" current="courses">
  <section class="wrap" style="padding: 56px 32px;">
    <div class="mono" style="color: var(--accent);">The Classroom</div>
    <h1 style="font-size: clamp(56px, 7vw, 88px); margin-top: 8px;">Small cohorts, taught from a working PM's <em style="color: var(--accent);">desk</em>.</h1>
    <p style="font-size: 22px; max-width: 720px; margin-top: 24px; color: var(--ink2);">
      Built to be useful on a Monday. You leave with a thing you shipped — not a binder. All courses recorded, transcribed, and refundable for 14 days.
    </p>

    <div style="margin-top: 56px; border-top: 2px solid var(--ink);">
      {courses.map((c) => (
        <a href={`/courses/${c.slug}/`} style="display: grid; grid-template-columns: 60px 1fr 220px 140px 40px; gap: 24px; padding: 32px 0; border-bottom: 1px solid var(--rule); align-items: center;">
          <div class="mono" style="color: var(--accent);">№ {String(c.data.order).padStart(2, '0')}</div>
          <div>
            <div style="font-size: 30px;">{c.data.title}</div>
            <div style="font-size: 15px; color: var(--muted); margin-top: 6px;">{c.data.summary}</div>
          </div>
          <div>
            <div>{c.data.schedule}</div>
            <div class="mono" style="margin-top: 4px;">{c.data.seats}</div>
          </div>
          <div style="font-size: 28px;">{c.data.price}</div>
          <div style="color: var(--accent); font-size: 22px; text-align: right;">→</div>
        </a>
      ))}
    </div>
  </section>
</Base>
